{"nodes": [{"id": "short_answer_validation_feature", "label": "Short Answer Validation", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "Adds configurable validation to short_answer question type with preset options (postal_code_prefix, email, custom regex) and an optional description/helper-text field for all question types. Immediate use case is postal code prefix demographic collection."}, {"id": "postal_code_prefix_validation", "label": "Postal Code Prefix (A1A)", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "A validation preset enforcing max 3 characters matching ^[A-Z][0-9][A-Z]$ with automatic uppercase normalization. Collects the first three characters of a Canadian postal code for demographic analysis without collecting full identifiable addresses."}, {"id": "email_validation_preset", "label": "Email Validation", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "A validation preset with regex ^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$ and max length of 254 characters. Provides standard email format checking."}, {"id": "custom_regex_validation", "label": "Custom Regex Validation", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "Admins can define their own regex pattern, max length, and uppercase normalization for arbitrary validation needs not covered by presets."}, {"id": "normalize_uppercase", "label": "Normalize Uppercase", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "Both client-side (on input change) and server-side (on save) normalization to uppercase for postal codes. Ensures consistent data format regardless of how users type their input."}, {"id": "dual_validation", "label": "Client + Server Validation", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "Validation runs both in the browser (before advancing to the next question) and on the server (PUT /api/sessions/{id}/answers). Client-side prevents bad data from being submitted; server-side prevents data quality issues at the persistence boundary."}, {"id": "upsert_answer_endpoint", "label": "PUT /api/sessions/{session_id}/answers", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "Existing auto-save endpoint for answers, extended with server-side validation logic that checks regex, max_length, and applies uppercase normalization before writing to the answers table."}, {"id": "validation_error_translations", "label": "Validation Error Translations", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "Error messages are translated to all three platform languages (en/fr/zh) via LanguageContext. Client-side only \u2014 server-side validation errors are not i18n'd, which is listed as out of scope."}, {"id": "validation_test_suite", "label": "test_short_answer_validation.py", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "Standalone Python test file covering valid postal codes, lowercase/mixed-case normalization, invalid formats, max length enforcement, empty required/optional handling, and validation config round-trip."}, {"id": "admin_create_page", "label": "Admin Create Page", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "The page at src/app/admin/create/page.tsx where admins compose new surveys. Extended with description field for all question types and validation config dropdown for short_answer questions."}, {"id": "admin_results_page", "label": "Admin Results Page", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "The page at src/app/admin/results/[id]/page.tsx showing survey response summaries. Extended to display question descriptions in both summary and individual response tabs."}, {"id": "respondent_survey_page", "label": "Respondent Survey Page", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "The page at src/app/survey/[id]/page.tsx where respondents fill out surveys. Extended with description rendering, validation-aware input (maxLength, uppercase normalization), and client-side validation on step advance."}, {"id": "language_context", "label": "LanguageContext", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "React context providing UI translation strings for en/fr/zh. Extended with validation error messages for postal code format errors in all three languages."}, {"id": "tailwind_css", "label": "Tailwind CSS", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "CSS utility framework used for all styling across the platform, including dark mode support via the dark: prefix variant."}, {"id": "validation_preset_constants", "label": "VALIDATION_PRESETS", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "A TypeScript constant mapping preset names to their regex, max_length, and normalize_uppercase values. Used on both admin create and edit pages to auto-fill validation fields when a preset is selected."}, {"id": "update_validation_type", "label": "updateValidationType Function", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "React state handler that updates question validation config when admin selects a preset. For non-regex presets, auto-fills regex/max_length/normalize fields."}, {"id": "question_draft_interface", "label": "QuestionDraft Interface", "file_type": "document", "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "rationale": "TypeScript interface representing a question in the admin editor. Extended with question_description, validation_type, validation_regex, validation_max_length, and validation_normalize_uppercase fields."}], "edges": [{"source": "pdf_translation_upload_feature", "target": "short_answer_validation_feature", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.8, "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "weight": 0.5}, {"source": "short_answer_validation_feature", "target": "validation_presets", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "weight": 1.0}, {"source": "short_answer_validation_feature", "target": "question_description_field", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "weight": 1.0}, {"source": "short_answer_validation_feature", "target": "dual_validation", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "weight": 1.0}, {"source": "short_answer_validation_feature", "target": "options_jsonb", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "weight": 1.0}, {"source": "short_answer_validation_feature", "target": "admin_create_page", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/plans/2026-05-27-short-answer-validation.md", "weight": 1.0}, {"source": "sho