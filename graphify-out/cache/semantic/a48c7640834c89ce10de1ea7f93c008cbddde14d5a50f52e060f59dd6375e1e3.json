{"nodes": [{"id": "gemini_prompt_strategy", "label": "Gemini Prompt Strategy", "file_type": "document", "source_file": "docs/superpowers/specs/2026-01-26-pdf-translation-upload-design.md", "rationale": "The prompt includes English reference questions with indices and types, the raw PDF text, and strict JSON schema instructions. Question mapping is position-based (by section+index) rather than text matching to avoid fragility across languages."}, {"id": "translation_error_handling", "label": "Translation Error Handling", "file_type": "document", "source_file": "docs/superpowers/specs/2026-01-26-pdf-translation-upload-design.md", "rationale": "Errors are categorized: non-PDF files (400), oversized files (413), Gemini failures (502), invalid JSON (502), mismatched question counts (partial mapping), unmatched sections (unmatched key). Graceful degradation ensures admin can still review and fix."}, {"id": "pdf_upload_data_flow", "label": "PDF Upload Data Flow", "file_type": "document", "source_file": "docs/superpowers/specs/2026-01-26-pdf-translation-upload-design.md", "rationale": "Admin uploads PDF \u2192 Backend extracts text \u2192 Gemini parses JSON \u2192 Maps indices to UUIDs \u2192 Upserts ai_analyses \u2192 Frontend re-fetches translations \u2192 Populates edit fields \u2192 Admin reviews and saves. Two-step save allows admin verification before persistence."}], "edges": [{"source": "pdf_translation_upload_feature", "target": "translation_error_handling", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-01-26-pdf-translation-upload-design.md", "weight": 1.0}, {"source": "pdf_translation_upload_feature", "target": "pdf_upload_data_flow", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/superpowers/specs/2026-01-26-pdf-translation-upload-design.md", "weight": 1.0}, {"source": "pdf_translation_upload_feature", "target": "gemini_prompt_strategy"